{
  "name": "@corp/shell-sdk",
  "version": "0.1.0",
  "description": "Shell SDK for Corp child apps",
  "main": "./dist/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tailwind": {
      "import": "./dist/esm/tailwind/preset.js",
      "require": "./dist/tailwind/preset.js",
      "types": "./dist/tailwind/preset.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.esm.json"
  },
  "peerDependencies": {
    "react": ">=18",
    "tailwindcss": ">=3"
  },
  "devDependencies": {
    "@types/react": "^19",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
